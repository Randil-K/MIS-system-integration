						"body": {
							"mode": "raw",
							"raw": "{\n  \"customer\": {\n    \"id\": 1\n  },\n  \"items\": [\n    {\n      \"product\": {\n        \"id\": 1\n      },\n      \"quantity\": 2\n    }\n  ],\n  \"status\": \"PENDING\"\n}",
