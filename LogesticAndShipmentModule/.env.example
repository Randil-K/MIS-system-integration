# =========================================================================
# ENVIRONMENT VARIABLES FOR LOGISTICS & SHIPMENT MODULE (DOCKER CONFIG)
# =========================================================================

# MySQL Database configuration
DB_NAME=logistics_db
DB_PASSWORD=rootpassword

# Backend Microservice configuration
PORT=8080

# Frontend Environment (Vite client-side environment variable)
# Note: This is injected during the Docker build stage
VITE_API_BASE_URL=http://localhost:8080/api

# Inter-service integration (URL of the Order & Billing backend service)
ORDER_SERVICE_URL=http://localhost:8082
